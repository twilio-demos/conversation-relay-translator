# AWS Configuration
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=CR-TRANSLATOR-AppDatabase

# AWS Credentials (for local development)
# In production, use IAM roles instead
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Public environment variables (accessible in browser)
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_DYNAMODB_TABLE=CR-TRANSLATOR-AppDatabase

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# External/public deployment mode
# When NEXT_PUBLIC_EXTERNAL=true, basic auth is used instead of Google OAuth
NEXT_PUBLIC_EXTERNAL=false

# Basic auth credentials (only used when NEXT_PUBLIC_EXTERNAL=true)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=changeme
BASIC_AUTH_SECRET=change-this-to-a-random-secret-at-least-32-chars
